pipeline {
  agent any

  tools {
    maven 'maven-3'
  }

  parameters {
    choice(name: 'SUITE', choices: ['smoke', 'sanity', 'regression', 'all'], description: 'Select the API suite to run')
  }

  stages {
    stage('Build') {
      steps {
        sh 'mvn -q test-compile'
      }
    }

    stage('API Suite') {
      steps {
        script {
          def command = params.SUITE == 'all' ? 'mvn test' : "mvn test -P${params.SUITE}"
          sh command
        }
      }
    }
  }

  post {
    always {
      junit allowEmptyResults: true, testResults: 'target/surefire-reports/*.xml'
      archiveArtifacts allowEmptyArchive: true, artifacts: 'target/allure-results/**/*'
    }
  }
}
