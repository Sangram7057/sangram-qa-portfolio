pipeline {
  agent any

  tools {
    maven 'maven-3'
  }

  parameters {
    choice(name: 'SUITE', choices: ['smoke', 'sanity', 'regression', 'all'], description: 'Select the Selenium suite to run')
  }

  stages {
    stage('Build') {
      steps {
        sh 'mvn -q test-compile'
      }
    }

    stage('UI Suite') {
      steps {
        script {
          def command = params.SUITE == 'all' ? 'mvn test' : "mvn test -P${params.SUITE}"
          sh command
        }
      }
    }
  }

  post {
    always {
      junit allowEmptyResults: true, testResults: 'target/surefire-reports/*.xml'
      archiveArtifacts allowEmptyArchive: true, artifacts: 'target/extent-report/**/*,target/allure-results/**/*,target/screenshots/**/*'
    }
  }
}
