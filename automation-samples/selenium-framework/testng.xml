<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Selenium QA Framework Sample Suite">
  <listeners>
    <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    <listener class-name="com.sangram.qa.listeners.TestListener"/>
  </listeners>
  <test name="Smoke Sanity Regression">
    <classes>
      <class name="com.sangram.qa.tests.SmokeSuiteTest"/>
      <class name="com.sangram.qa.tests.SanitySuiteTest"/>
      <class name="com.sangram.qa.tests.RegressionSuiteTest"/>
    </classes>
  </test>
</suite>
