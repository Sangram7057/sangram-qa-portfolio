<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Selenium Regression Suite">
  <listeners>
    <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    <listener class-name="com.sangram.qa.listeners.TestListener"/>
  </listeners>
  <test name="Regression Tagged Scenarios">
    <groups>
      <run>
        <include name="regression"/>
      </run>
    </groups>
    <packages>
      <package name="com.sangram.qa.tests"/>
    </packages>
  </test>
</suite>
