{
  "servers": {
    "playwright-qa-smoke-server": {
      "type": "stdio",
      "command": "npx",
      "args": ["tsx", "playwright-framework/mcp/playwright-mcp-server.ts"],
      "env": {
        "BASE_URL": "https://example.test-app.local",
        "TEST_USERNAME": "demo.user",
        "TEST_PASSWORD": "replace-me"
      }
    },
    "playwright-qa-regression-sanity-server": {
      "type": "stdio",
      "command": "npx",
      "args": ["tsx", "playwright-framework/mcp/playwright-mcp-regression-sanity-server.ts"],
      "env": {
        "BASE_URL": "https://example.test-app.local",
        "TEST_USERNAME": "demo.user",
        "TEST_PASSWORD": "replace-me"
      }
    }
  }
}
